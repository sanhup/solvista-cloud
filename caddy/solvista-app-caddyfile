app.solvista.nl {

    handle_path /iam/* {
        root * /opt/apps/solvista-iam/frontend
        file_server

        # SPA routing
        try_files {path} /index.html

        # Cache busted assets (Vite fingerprints filenames)
        @static {
            path *.js *.css *.png *.jpg *.jpeg *.gif *.svg *.ico *.woff *.woff2
        }
        header @static Cache-Control "public, max-age=31536000, immutable"

        # HTML must revalidate
        @html {
            path *.html
        }
        header @html Cache-Control "no-cache"

        header {
            X-Content-Type-Options nosniff
            X-Frame-Options DENY
            Referrer-Policy strict-origin-when-cross-origin
        }
        encode gzip
    }

    handle_path /components/* {
        root * /opt/apps/solvista-components
        file_server

        # Versioned URLs — safe to cache forever
        header Cache-Control "public, max-age=31536000, immutable"
        header Access-Control-Allow-Origin "*"
        header {
            X-Content-Type-Options nosniff
            Referrer-Policy strict-origin-when-cross-origin
        }
        encode gzip
    }

    handle_path /router/* {
        root * /opt/apps/solvista-router
        file_server

        # Versioned URLs — safe to cache forever
        header Cache-Control "public, max-age=31536000, immutable"
        header Access-Control-Allow-Origin "*"
        header {
            X-Content-Type-Options nosniff
            Referrer-Policy strict-origin-when-cross-origin
        }
        encode gzip
    }

    # Add this block inside the app.solvista.nl site in solvista-cloud
    handle_path /wiki* {
        reverse_proxy 127.0.0.1:9001

        header {
            X-Content-Type-Options nosniff
            Referrer-Policy strict-origin-when-cross-origin
        }
    }

}
