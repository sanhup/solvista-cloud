# PostgreSQL admin (used by the postgres container)
POSTGRES_PASSWORD=changeme

# Application database (created by postgres/init.sh, used by backend)
# MY_APP_DB=my_app
# MY_APP_USER=my_app
# MY_APP_PASSWORD=changeme
# MY_APP_HOST=my_app_postgres
# MY_APP_PORT=5432

# Environment: development | staging | production
ENVIRONMENT=production

# JWT Configuration
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private_key.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public_key.pem
JWT_TTL_SECONDS=900
JWT_ALGORITHM=RS256
JWT_ISSUER=my-app

# Refresh Token
REFRESH_TOKEN_TTL_SECONDS=604800

# CORS
ALLOWED_ORIGINS=https://app.solvista.nl

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Application
PYTHONUNBUFFERED=1
